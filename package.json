{
  "name": "timetable-sa-docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --host=0.0.0.0 --port=5173",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "preview": "vite preview",
    "typecheck": "npm run types:check",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "validate:frontmatter": "node scripts/validate-frontmatter.mjs",
    "check:links": "node scripts/check-links.mjs",
    "ci:check": "npm run typecheck && npm run build && npm run validate:frontmatter && npm run check:links",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-start": "1.167.12",
    "fumadocs-core": "16.7.7",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.7",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tslib": "^2.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
